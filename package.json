{
  "name": "comment-translate-cloudflare",
  "displayName": "comment-translate-cloudflare",
  "description": "A Cloudflare AI translation source for comment-translate",
  "version": "0.0.1",
  "publisher": "AkimioJR",
  "author": {
    "email": "akimio.jr@gmail.com",
    "name": "AkimioJR"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "translates": [
      {
        "translate": "cloudflare",
        "title": "Cloudflare translate"
      }
    ],
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "cloudflareTranslate.accountId": {
          "type": "string",
          "default": "",
          "description": "%configuration.cloudflareTranslate.accountId.description%"
        },
        "cloudflareTranslate.apiToken": {
          "type": "string",
          "default": "",
          "description": "%configuration.cloudflareTranslate.apiToken.description%"
        },
        "cloudflareTranslate.model": {
          "type": "string",
          "default": "@cf/meta/llama-3.1-8b-instruct",
          "description": "%configuration.cloudflareTranslate.model.description%"
        },
        "cloudflareTranslate.systemPrompt": {
          "type": "string",
          "default": "%configuration.cloudflareTranslate.systemPrompt.default%",
          "description": "%configuration.cloudflareTranslate.systemPrompt.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "comment-translate-manager": "^0.0.5"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "typescript-eslint": "^8.56.1",
    "eslint": "^10.2.0",
    "typescript": "^6.0.2",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}